{
  "name": "basalt",
  "version": "0.1.0",
  "private": true,
  "description": "Basalt — kanban git-native. Tarefas em markdown, versionadas no git. Local-first, dark.",
  "scripts": {
    "dev": "concurrently -n server,app -c blue,green \"npm:dev:server\" \"npm:dev:app\"",
    "dev:server": "node --watch server/index.js",
    "dev:app": "vite --config app/vite.config.js app",
    "build": "vite build --config app/vite.config.js app",
    "start": "node server/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-bubble-menu": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@tiptap/suggestion": "^2.27.2",
    "chokidar": "^3.6.0",
    "expr-eval": "^2.0.2",
    "express": "^4.19.2",
    "gray-matter": "^4.0.3",
    "simple-git": "^3.25.0",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.8.10"
  },
  "devDependencies": {
    "@vitejs/plugin-vue2": "^2.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "vue": "^2.7.16",
    "vuedraggable": "^2.24.3"
  }
}
